# ===== Solution Validation =====

msgid "Solution text is empty."
msgstr "O texto da solução está vazio."

msgid "Quality Audit not configured for this entity"
msgstr "Auditoria de Qualidade não configurada para esta entidade"

msgid "AI quality audit service is temporarily unavailable."
msgstr "O serviço de auditoria de qualidade por IA está temporariamente indisponível."

msgid "Solution indicates problem was not resolved. Cannot provide improvement suggestion."
msgstr "A solução indica que o problema não foi resolvido. Não é possível fornecer sugestão de melhoria."

msgid "Solution is very short (less than 20 characters)"
msgstr "A solução é muito curta (menos de 20 caracteres)"

msgid "Solution is short. Consider adding more details."
msgstr "A solução é curta. Considere adicionar mais detalhes."

msgid "Avoid generic responses like \"%s\". Explain what was done."
msgstr "Evite respostas genéricas como \"%s\". Explique o que foi feito."

msgid "Solution should have at least 2 sentences explaining the actions taken."
msgstr "A solução deve ter pelo menos 2 frases explicando as ações tomadas."

msgid "Good: Contains technical action words."
msgstr "Bom: Contém palavras de ação técnica."

msgid "Consider adding specific actions taken (e.g., \"configured\", \"restarted\", \"verified\")."
msgstr "Considere adicionar ações específicas realizadas (ex.: \"configurado\", \"reiniciado\", \"verificado\")."

# ===== Welcome / Setup =====

msgid "Quality Audit Setup"
msgstr "Configuração Inicial do Quality Audit"

msgid "Welcome to Quality Audit!"
msgstr "Bem-vindo ao Quality Audit!"

msgid "Follow the steps below to activate AI-powered solution auditing."
msgstr "Siga os passos abaixo para ativar a auditoria de soluções por IA."

msgid "complete"
msgstr "completo"

msgid "Configure & Test API Connection"
msgstr "Configurar e Testar Conexão com API"

msgid "Choose your AI provider, enter the API key, select the model, and test the connection. Everything is on the same page."
msgstr "Escolha seu provedor de IA, insira a chave da API, selecione o modelo e teste a conexão. Tudo na mesma página."

msgid "Connected"
msgstr "Conectado"

msgid "Key saved"
msgstr "Chave salva"

msgid "Edit Configuration"
msgstr "Editar Configuração"

msgid "API Key missing"
msgstr "Chave da API ausente"

msgid "Open Configuration"
msgstr "Abrir Configuração"

msgid "Enable Automatic Auditing"
msgstr "Ativar Auditoria Automática"

msgid "When enabled, every solution added to a ticket will be automatically evaluated by AI and scored based on quality criteria."
msgstr "Quando ativado, toda solução adicionada a um chamado será automaticamente avaliada por IA e pontuada com base em critérios de qualidade."

msgid "Complete Step 1 first"
msgstr "Complete o Passo 1 primeiro"

msgid "Auto Audit is ON"
msgstr "Auditoria Automática LIGADA"

msgid "Threshold"
msgstr "Limite"

msgid "Adjust Rules"
msgstr "Ajustar Regras"

msgid "Auto Audit is OFF"
msgstr "Auditoria Automática DESLIGADA"

msgid "The plugin will not audit solutions until this is enabled."
msgstr "O plugin não auditará soluções até que isto seja ativado."

msgid "Enable in Configuration"
msgstr "Ativar na Configuração"

msgid "Monitor Results"
msgstr "Monitorar Resultados"

msgid "Once configured and enabled, audit results will appear on the dashboard automatically as technicians close tickets."
msgstr "Uma vez configurado e ativado, os resultados das auditorias aparecerão no painel automaticamente conforme os técnicos fecham chamados."

msgid "Waiting for setup"
msgstr "Aguardando configuração"

msgid "Everything is set up! Audits will start appearing here as soon as a technician adds a solution to a ticket."
msgstr "Tudo configurado! As auditorias começarão a aparecer aqui assim que um técnico adicionar uma solução a um chamado."

msgid "Waiting for first audit..."
msgstr "Aguardando primeira auditoria..."

msgid "Open Dashboard"
msgstr "Abrir Painel"

msgid "You already have %d audit(s) recorded. Check the dashboard for scores, trends, and reports."
msgstr "Você já tem %d auditoria(s) registrada(s). Confira o painel para notas, tendências e relatórios."

msgid "%d audits"
msgstr "%d auditorias"

